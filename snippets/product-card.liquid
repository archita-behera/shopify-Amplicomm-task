<div class="product-card">
  <a href="{{ product.url }}">
    {% if product.featured_image %}
      <img src="{{ product.featured_image | img_url: '400x' }}" 
           alt="{{ product.featured_image.alt | escape }}"
           loading="lazy">
    {% else %}
      <div style="height:220px;background:#f5f5f5;display:flex;align-items:center;justify-content:center;color:#999;">No Image</div>
    {% endif %}
  </a>
  <div class="product-card-info">
    {% if product.tags contains 'featured' %}
      <span class="featured-badge">⭐ Featured</span>
    {% endif %}
    <div class="product-card-title">
      <a href="{{ product.url }}" style="color:inherit;text-decoration:none;">{{ product.title }}</a>
    </div>
    <div class="product-card-price">{{ product.price | money }}</div>
  </div>
</div>