{% paginate collection.products by 20 %}

<div
  id="featured-collection-root"
  data-collection-handle="{{ collection.handle }}"
  data-current-page="{{ paginate.current_page }}"
  data-total-pages="{{ paginate.pages }}"
>

  <script id="collection-products-json" type="application/json">
    [
      {%- for product in collection.products -%}
        {
          "id": {{ product.id | json }},
          "title": {{ product.title | json }},
          "handle": {{ product.handle | json }},
          "url": {{ product.url | json }},
          "tags": {{ product.tags | json }},
          "featured_image": {{ product.featured_image | img_url: '500x500' | json }},
          "price": {{ product.price | money | json }},
          "compare_at_price": {{ product.compare_at_price | money | json }},
          "available": {{ product.available | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>

  <div class="fic-toolbar">

    <div>
      <select id="fic-sort-select" onchange="ficHandleSort(this.value)">
        <option value="manual">Featured</option>
        <option value="best-selling">Best Selling</option>
        <option value="price-ascending">Price Low → High</option>
        <option value="price-descending">Price High → Low</option>
      </select>
    </div>

    <div id="fic-product-count"></div>

  </div>

  <div id="fic-featured-label" style="display:none;">
    <h2>⭐ Featured Products</h2>
  </div>

  <div id="fic-grid" class="fic-grid"></div>

  <div id="fic-divider" style="display:none;">
    <h2>All Products</h2>
  </div>

  <div id="fic-normal-grid" class="fic-grid"></div>

  <div id="fic-loader" style="display:none;">
    Loading products...
  </div>

  <div id="fic-end-msg" style="display:none;">
    All products loaded
  </div>

  <div id="fic-sentinel"></div>

</div>

<script src="{{ 'featured-infinite-scroll.js' | asset_url }}" defer></script>

<style>

.fic-toolbar{
display:flex;
justify-content:space-between;
margin-bottom:20px;
}

.fic-grid{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:20px;
margin-bottom:30px;
}

.fic-card{
border:1px solid #eee;
padding:10px;
text-decoration:none;
color:#000;
display:block;
}

.fic-card img{
width:100%;
height:250px;
object-fit:cover;
}

.fic-title{
font-size:14px;
margin-top:10px;
}

.fic-price{
font-weight:bold;
margin-top:5px;
}

.fic-badge{
display:inline-block;
background:#ffc107;
padding:4px 10px;
font-size:12px;
margin-bottom:8px;
}

#fic-loader,
#fic-end-msg{
text-align:center;
padding:20px;
}

</style>

{% endpaginate %}

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "class": "featured-collection-section",
  "settings": [],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
