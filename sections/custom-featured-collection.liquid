<div
  id="featured-collection-root"
  data-collection-handle="{{ collection.handle }}"
  data-total-products="{{ collection.products_count }}"
  data-sort-by="{{ collection.sort_by }}"
>

  {%- comment -%} Pass ALL product data to JS via JSON — max 250 products via Liquid {%- endcomment -%}
  <script id="collection-products-json" type="application/json">
    [
      {%- for product in collection.products limit: 250 -%}
        {
          "id": {{ product.id | json }},
          "title": {{ product.title | json }},
          "handle": {{ product.handle | json }},
          "url": {{ product.url | json }},
          "tags": {{ product.tags | json }},
          "featured_image": {{ product.featured_image | img_url: '400x400' | json }},
          "price": {{ product.price | money | json }},
          "compare_at_price": {{ product.compare_at_price | money | json }},
          "available": {{ product.available | json }},
          "vendor": {{ product.vendor | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  </script>

  {%- comment -%} Sort & Filter bar {%- endcomment -%}
  <div class="fic-toolbar">
    <div class="fic-sort">
      <label for="fic-sort-select">Sort by:</label>
      <select id="fic-sort-select" onchange="ficHandleSort(this.value)">
        <option value="manual" {% if collection.sort_by == 'manual' %}selected{% endif %}>Featured</option>
        <option value="best-selling" {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
        <option value="price-ascending" {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Price: Low → High</option>
        <option value="price-descending" {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Price: High → Low</option>
        <option value="title-ascending" {% if collection.sort_by == 'title-ascending' %}selected{% endif %}>A → Z</option>
        <option value="title-descending" {% if collection.sort_by == 'title-descending' %}selected{% endif %}>Z → A</option>
      </select>
    </div>
    <div class="fic-count">
      <span id="fic-product-count">Loading...</span>
    </div>
  </div>

  {%- comment -%} Featured badge row {%- endcomment -%}
  <div id="fic-featured-label" class="fic-section-label" style="display:none">
    <span>⭐ Featured Products</span>
  </div>

  {%- comment -%} Main product grid {%- endcomment -%}
  <div id="fic-grid" class="fic-grid"></div>

  {%- comment -%} Divider between featured and normal {%- endcomment -%}
  <div id="fic-divider" class="fic-divider" style="display:none">
    <span>All Products</span>
  </div>

  {%- comment -%} Normal products grid {%- endcomment -%}
  <div id="fic-normal-grid" class="fic-grid"></div>

  {%- comment -%} Infinite scroll sentinel {%- endcomment -%}
  <div id="fic-sentinel" style="height:1px;margin-top:40px;"></div>

  {%- comment -%} Loading spinner {%- endcomment -%}
  <div id="fic-loader" class="fic-loader" style="display:none">
    <div class="fic-spinner"></div>
    <span>Loading more products...</span>
  </div>

  {%- comment -%} End message {%- endcomment -%}
  <div id="fic-end-msg" class="fic-end-msg" style="display:none">
    ✓ All products loaded
  </div>

</div>

{%- comment -%} Inject our JS {%- endcomment -%}
<script src="{{ 'custom-featured-infinite-scroll.js' | asset_url }}" defer></script>

<style>
  .fic-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    border-bottom: 1px solid #e5e5e5;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .fic-sort {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .fic-sort label {
    font-size: 14px;
    color: #555;
  }
  .fic-sort select {
    padding: 6px 12px;
    border: 1px solid #ccc;
    border-radius: 6px;
    font-size: 14px;
    cursor: pointer;
    background: #fff;
  }
  .fic-count {
    font-size: 14px;
    color: #888;
  }
  .fic-section-label {
    margin: 0 0 16px;
  }
  .fic-section-label span {
    font-size: 18px;
    font-weight: 600;
    color: #222;
  }
  .fic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 24px;
    margin-bottom: 24px;
  }
  .fic-card {
    border: 1px solid #eee;
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
    transition: box-shadow 0.2s, transform 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .fic-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.10);
    transform: translateY(-2px);
  }
  .fic-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    background: #f5f5f5;
  }
  .fic-card-body {
    padding: 12px;
  }
  .fic-card-title {
    font-size: 14px;
    font-weight: 500;
    margin: 0 0 6px;
    color: #222;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .fic-card-price {
    font-size: 14px;
    color: #444;
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .fic-card-compare {
    text-decoration: line-through;
    color: #999;
    font-size: 13px;
  }
  .fic-card-badge {
    display: inline-block;
    background: #fff3cd;
    color: #856404;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
    margin-bottom: 6px;
    border: 1px solid #ffc107;
  }
  .fic-divider {
    text-align: center;
    margin: 32px 0 24px;
    position: relative;
  }
  .fic-divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0; right: 0;
    height: 1px;
    background: #e5e5e5;
  }
  .fic-divider span {
    position: relative;
    background: #fff;
    padding: 0 16px;
    font-size: 16px;
    font-weight: 600;
    color: #444;
  }
  .fic-loader {
    text-align: center;
    padding: 32px;
    color: #888;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }
  .fic-spinner {
    width: 20px; height: 20px;
    border: 2px solid #ddd;
    border-top-color: #333;
    border-radius: 50%;
    animation: fic-spin 0.7s linear infinite;
  }
  @keyframes fic-spin { to { transform: rotate(360deg); } }
  .fic-end-msg {
    text-align: center;
    padding: 24px;
    color: #aaa;
    font-size: 14px;
  }
  .fic-card-unavailable {
    opacity: 0.6;
  }
  .fic-unavailable-badge {
    display: inline-block;
    background: #f8d7da;
    color: #842029;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
    margin-bottom: 6px;
  }
</style>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "class": "featured-collection-section",
  "settings": [],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
